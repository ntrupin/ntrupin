{% extends "base.jinja" %}
{% block content %}
<section class="profile-page portfolio-home">
  <section class="home-hero" aria-labelledby="home-title">
    <div class="home-intro">
      <p class="home-kicker">Portfolio</p>
      <h1 id="home-title" class="home-title">Hi, I'm <br /> <span class="home-name">Noah Trupin</span>.</h1>
      <p class="home-summary">
        I am a third-year computer science honors student at Purdue, working across machine learning, robotics, and languages.
      </p>
    </div>
    <aside class="home-note" aria-label="About this site">
      <p class="home-note-label">Current</p>
      <p class="home-note-copy">
        My personal archive for projects, writing, and small experiments.
      </p>
      <p class="home-note-copy">
        Right now I am researching <i>error bounds for diffusion networks</i> under <a href="https://www.cs.purdue.edu/homes/yexiang/">Yexiang Xue</a>, <i>robot perception and planning</i> under <a href="https://qureshiahmed.github.io/">Ahmed Qureshi</a>, and <i>verification of stochastic systems</i> alongside <a href="https://pauljiang.com/">Paul Jiang</a>. I will join Optiver as a software engineer intern in Summer 2026.
      </p>
    </aside>
  </section>

  <section class="home-map" aria-labelledby="browse-heading">
    <h2 id="browse-heading" class="section-title">Browse</h2>
    <div class="home-map-grid">
      <a href="{{ url_for('projects.index') }}" class="home-panel">
        <p class="home-panel-index">01</p>
        <h2 class="home-panel-title">Projects</h2>
        <p class="home-panel-copy">Research work, software systems, and experiments.</p>
      </a>
      <a href="{{ url_for('writing.index') }}" class="home-panel">
        <p class="home-panel-index">02</p>
        <h2 class="home-panel-title">Writing</h2>
        <p class="home-panel-copy">Essays, notes, and longer drafts in progress.</p>
      </a>
      <a href="{{ url_for('cv') }}" class="home-panel">
        <p class="home-panel-index">03</p>
        <h2 class="home-panel-title">CV</h2>
        <p class="home-panel-copy">Experience, awards, publications, and academic work.</p>
      </a>
    </div>
  </section>

  <section class="home-details" aria-label="Practice and background">
    <div class="home-detail">
      <h2 class="section-title">Practice</h2>
      <p class="home-detail-copy">
        I am especially interested in programming languages and compilers as tools for building both domain-specific, high-performance systems, and the future of machine intellignece.
      </p>
    </div>
    <div class="home-detail">
      <h2 class="section-title">Background</h2>
      <p class="home-detail-copy">
        I worked as a software engineer on Virtual Cards at Capital One, built out experimental trading markets as a founding engineer at Straato, and conducted research across numerical and high performance computing, machine learning, and robotics.
      </p>
    </div>
    <div class="home-detail">
      <h2 class="section-title">Contact</h2>
      <p class="home-detail-copy">
        Email: ntrupin 「at」 purdue 「dot」 edu <br />
        X: <a href="https://x.com/ntrupin">@ntrupin</a> <br />
        LinkedIn: <a href="https://linkedin.com/in/ntrupin">ntrupin</a> <br />
      </p>
    </div>
  </section>

  <section class="home-updates" aria-labelledby="updates-heading">
    <div class="home-updates-header">
      <h2 id="updates-heading" class="section-title">Recent updates</h2>
      <p class="home-updates-intro">Recent updates.</p>
    </div>
    <div class="home-updates-list">
      {% include "partials/updates.jinja" %}
    </div>
  </section>
</section>
{% endblock %}

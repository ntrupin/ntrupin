<aside class="nav-aside">
  <div class="nav-sticky">
    <nav class="nav-scroll" id="nav" aria-label="Primary">
      <div class="nav-items">
        <a href="/" class="nav-item" data-active="{{ 'true' if request.path == '/' else 'false' }}">Home</a>
        {% for url, data in links.items() %}
        {% if url != "/" %}
        {% set external = data.external if data.external is defined else false %}
        {% set normalized = url if url.endswith('/') else url + '/' %}
        {% set is_active = (not external) and (request.path == normalized or (normalized != "/" and request.path.startswith(normalized))) %}
        <a
          href="{{ url }}"
          class="nav-item"
          data-active="{{ 'true' if is_active else 'false' }}"
          {% if external %}target="_blank" rel="noopener noreferrer"{% endif %}
        >
          {{ data.name }}
        </a>
        {% endif %}
        {% endfor %}
        {% if g.user and g.user.is_admin %}
        <a href="{{ url_for('admin.index') }}" class="nav-item" data-active="{{ 'true' if request.path.startswith('/admin/') else 'false' }}">Admin</a>
        {% endif %}
        {% if g.user %}
        <form action="{{ url_for('auth.logout') }}" method="post" class="nav-form">
          <input type="hidden" name="csrf_token" value="{{ csrf_token }}" />
          <button type="submit" class="nav-item nav-button" data-active="false">Logout</button>
        </form>
        {% endif %}
      </div>
    </nav>
  </div>
</aside>

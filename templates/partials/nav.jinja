<header class="top-nav fade-in">
  <div class="top-nav-row">
    <a href="/" class="site-brand" data-active="{{ 'true' if request.path == '/' else 'false' }}">Noah Trupin</a>
    <nav id="nav" class="top-nav-links" aria-label="Primary">
    {% for url, data in links.items() %}
    {% if url != "/" %}
    {% set external = data.external if data.external is defined else false %}
    {% set normalized = url if url.endswith('/') else url + '/' %}
    {% set is_active = (not external) and (request.path == normalized or (normalized != "/" and request.path.startswith(normalized))) %}
    <a
      href="{{ url }}"
      class="nav-link"
      data-active="{{ 'true' if is_active else 'false' }}"
      {% if external %}target="_blank" rel="noopener noreferrer"{% endif %}
    >
      {{ data.name }}
    </a>
    {% endif %}
    {% endfor %}
    {% if g.user %}
    {% if g.user.is_admin %}
    <a href="{{ url_for('admin.index') }}" class="nav-link" data-active="{{ 'true' if request.path.startswith('/admin/') else 'false' }}">Admin</a>
    {% endif %}
    <form action="{{ url_for('auth.logout') }}" method="post" class="nav-link-form">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}" />
      <button type="submit" class="nav-link nav-link-button" data-active="false">Logout</button>
    </form>
    {% else %}
    <a href="{{ url_for('auth.login') }}" class="nav-link" data-active="{{ 'true' if request.path.startswith('/auth/login/') else 'false' }}">Login</a>
    {% endif %}
    </nav>
  </div>
</header>

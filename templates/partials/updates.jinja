<div class="blog-list" role="list">
  {% for update in updates %}
  <article class="blog-row" role="listitem">
    <div class="blog-row-main">
      <p class="blog-date update-date">{{ update.date.strftime("%b %d, %Y") }}</p>
      <div class="blog-main-text">
        <p class="blog-title">{{ update.description | trim }}</p>
      </div>
    </div>
  </article>
  {% else %}
  <p class="muted">No updates yet.</p>
  {% endfor %}
</div>
{% if request.path != "/updates/" %}
<p class="blog-more"><a href="{{ url_for('updates') }}">All updates →</a></p>
{% endif %}

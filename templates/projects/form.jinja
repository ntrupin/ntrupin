{% macro form_for(object, available_groups=[], selected_group_ids=[], show_group_selector=true) %}
{% if object is mapping %}
{% set title_value = object.get("title") or "" %}
{% set deck_value = object.get("deck") or "" %}
{% set summary_value = object.get("summary") or "" %}
{% set started_on_value = object.get("started_on") or "" %}
{% set ended_on_value = object.get("ended_on") or "" %}
{% set status_value = object.get("status") or "" %}
{% set stack_value = object.get("stack") or "" %}
{% set project_url_value = object.get("project_url") or "" %}
{% set repo_url_value = object.get("repo_url") or "" %}
{% set paper_url_value = object.get("paper_url") or "" %}
{% set content_value = object.get("content") or "" %}
{% set research_value = object.get("research", false) %}
{% set pinned_value = object.get("pinned", false) %}
{% set public_value = object.get("public", false) %}
{% else %}
{% set title_value = (object.title or "") if object and object.title is defined else "" %}
{% set deck_value = (object.deck or "") if object and object.deck is defined else "" %}
{% set summary_value = (object.summary or "") if object and object.summary is defined else "" %}
{% set started_on_value = object.started_on.strftime("%Y-%m-%d") if object and object.started_on is defined and object.started_on else "" %}
{% set ended_on_value = object.ended_on.strftime("%Y-%m-%d") if object and object.ended_on is defined and object.ended_on else "" %}
{% set status_value = (object.status or "") if object and object.status is defined else "" %}
{% set stack_value = (object.stack or "") if object and object.stack is defined else "" %}
{% set project_url_value = (object.project_url or "") if object and object.project_url is defined else "" %}
{% set repo_url_value = (object.repo_url or "") if object and object.repo_url is defined else "" %}
{% set paper_url_value = (object.paper_url or "") if object and object.paper_url is defined else "" %}
{% set content_value = (object.content or "") if object and object.content is defined else "" %}
{% set research_value = object.research if object and object.research is defined else false %}
{% set pinned_value = object.pinned if object and object.pinned is defined else false %}
{% set public_value = object.public if object and object.public is defined else false %}
{% endif %}
<form method="post" class="form-block">
  <input type="hidden" name="csrf_token" value="{{ csrf_token }}" />

  <label class="field">
    <span class="field-label">Title</span>
    <input name="title" id="title" value="{{ title_value }}" class="input" required />
  </label>

  <label class="field">
    <span class="field-label">Deck</span>
    <textarea name="deck" id="deck" class="input textarea-small">{{ deck_value }}</textarea>
  </label>

  <label class="field">
    <span class="field-label">Summary</span>
    <textarea name="summary" id="summary" class="input textarea-small" required>{{ summary_value }}</textarea>
  </label>

  <div class="field-grid-2">
    <label class="field">
      <span class="field-label">Start date</span>
      <input type="date" name="started_on" id="started_on" value="{{ started_on_value }}" class="input" />
    </label>
    <label class="field">
      <span class="field-label">End date</span>
      <input type="date" name="ended_on" id="ended_on" value="{{ ended_on_value }}" class="input" />
    </label>
  </div>

  <label class="field">
    <span class="field-label">Status</span>
    <input name="status" id="status" value="{{ status_value }}" class="input" placeholder="Live, In progress, Archived" />
  </label>

  <label class="field">
    <span class="field-label">Stack</span>
    <input name="stack" id="stack" value="{{ stack_value }}" class="input" placeholder="Python, Flask, Supabase" />
  </label>

  <label class="field">
    <span class="field-label">Project URL</span>
    <input type="url" name="project_url" id="project_url" value="{{ project_url_value }}" class="input" />
  </label>

  <label class="field">
    <span class="field-label">Repository URL</span>
    <input type="url" name="repo_url" id="repo_url" value="{{ repo_url_value }}" class="input" />
  </label>

  <label class="field">
    <span class="field-label">Paper URL</span>
    <input type="url" name="paper_url" id="paper_url" value="{{ paper_url_value }}" class="input" />
  </label>

  <label class="field">
    <span class="field-label">Notes</span>
    <textarea name="content" id="content" class="input textarea-large">{{ content_value }}</textarea>
  </label>

  <label class="choice">
    <input type="checkbox" name="research" id="research" class="checkbox" {{ "checked" if research_value == true }} />
    <span>Research</span>
  </label>

  <label class="choice">
    <input type="checkbox" name="pinned" id="pinned" class="checkbox" {{ "checked" if pinned_value == true }} />
    <span>Pinned</span>
  </label>

  <label class="choice">
    <input type="checkbox" name="public" id="public" class="checkbox" {{ "checked" if public_value == true }} />
    <span>Public</span>
  </label>

  {% if show_group_selector and available_groups %}
  {% set group_select_size = available_groups|length %}
  {% if group_select_size > 6 %}
  {% set group_select_size = 6 %}
  {% endif %}
  <label class="field">
    <span class="field-label">Allowed groups</span>
    <select name="group_ids" id="group_ids" class="input" multiple size="{{ group_select_size }}">
      {% for group in available_groups %}
      <option
        value="{{ group.id }}"
        {{ "selected" if group.id in selected_group_ids or group.id|string in selected_group_ids }}
      >
        {{ group.name }}
      </option>
      {% endfor %}
    </select>
    <span class="field-help">Leave empty for owner-only access when Public is unchecked.</span>
  </label>
  {% endif %}

  <button type="submit" class="button">Save</button>
</form>
{% endmacro %}

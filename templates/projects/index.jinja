{% extends "base.jinja" %}
{% block content %}
{% set featured_projects = projects | selectattr("pinned") | list %}
{% set archive_projects = projects | rejectattr("pinned") | list %}
<section>
  {% if g.user != None %}
  <a class="utility-button" href="{{ url_for('projects.create') }}">New project</a>
  {% endif %}
  <h1 class="list-page-title">Projects</h1>

  {% if featured_projects %}
  <h2 class="section-title">Selected</h2>
  <div class="blog-list" role="list">
    {% for project in featured_projects %}
    {% set groups = project.visibility_groups if project.visibility_groups is defined else [] %}
    <a
      href="{{ url_for('projects.show_canonical', name=project.canonical_url) if project.canonical_url else url_for('projects.show_id', id=project.id) }}"
      class="blog-row"
      role="listitem"
    >
      <div class="blog-row-main">
        <p class="blog-date project-date">
          {% if project.started_on and project.ended_on %}
          <span class="project-date-line">{{ project.started_on.strftime("%b %Y") }}</span>
          <span class="project-date-mobile-sep"> - </span>
          <span class="project-date-line">{{ project.ended_on.strftime("%b %Y") }}</span>
          {% elif project.started_on %}
          <span class="project-date-line">{{ project.started_on.strftime("%b %Y") }}</span>
          <span class="project-date-mobile-sep"> - </span>
          <span class="project-date-line">Present</span>
          {% elif project.ended_on %}
          <span class="project-date-line">Through</span>
          <span class="project-date-mobile-sep"> </span>
          <span class="project-date-line">{{ project.ended_on.strftime("%b %Y") }}</span>
          {% else %}
          {{ project.published_at.strftime("%b %d, %Y") }}
          {% endif %}
        </p>
        <div class="blog-main-text">
          <p class="blog-title">{{ project.title }}</p>
          {% if project.deck or project.summary %}
          <p class="blog-summary">{{ project.deck if project.deck else project.summary }}</p>
          {% endif %}
          {% if project.research == true or project.pinned == true or project.public == false or groups %}
          <p class="badge-line">
            {% if project.research == true %}<span class="badge">Research</span>{% endif %}
            {% if project.pinned == true %}<span class="badge">Pinned</span>{% endif %}
            {% if groups %}
            <span class="badge badge-private">Groups: {{ groups | join(", ") }}</span>
            {% elif project.public == false %}
            <span class="badge badge-private">Private</span>
            {% endif %}
          </p>
          {% endif %}
        </div>
      </div>
    </a>
    {% endfor %}
  </div>
  {% endif %}

  {% if archive_projects %}
  <h2 class="section-title section-title-archive">{% if featured_projects %}Archive{% else %}All{% endif %}</h2>
  <div class="blog-list" role="list">
    {% for project in archive_projects %}
    {% set groups = project.visibility_groups if project.visibility_groups is defined else [] %}
    <a
      href="{{ url_for('projects.show_canonical', name=project.canonical_url) if project.canonical_url else url_for('projects.show_id', id=project.id) }}"
      class="blog-row"
      role="listitem"
    >
      <div class="blog-row-main">
        <p class="blog-date project-date">
          {% if project.started_on and project.ended_on %}
          <span class="project-date-line">{{ project.started_on.strftime("%b %Y") }}</span>
          <span class="project-date-mobile-sep"> - </span>
          <span class="project-date-line">{{ project.ended_on.strftime("%b %Y") }}</span>
          {% elif project.started_on %}
          <span class="project-date-line">{{ project.started_on.strftime("%b %Y") }}</span>
          <span class="project-date-mobile-sep"> - </span>
          <span class="project-date-line">Present</span>
          {% elif project.ended_on %}
          <span class="project-date-line">Through</span>
          <span class="project-date-mobile-sep"> </span>
          <span class="project-date-line">{{ project.ended_on.strftime("%b %Y") }}</span>
          {% else %}
          {{ project.published_at.strftime("%b %d, %Y") }}
          {% endif %}
        </p>
        <div class="blog-main-text">
          <p class="blog-title">{{ project.title }}</p>
          {% if project.summary %}<p class="blog-summary">{{ project.summary }}</p>{% endif %}
          {% if project.research == true or project.pinned == true or project.public == false or groups %}
          <p class="badge-line">
            {% if project.research == true %}<span class="badge">Research</span>{% endif %}
            {% if project.pinned == true %}<span class="badge">Pinned</span>{% endif %}
            {% if groups %}
            <span class="badge badge-private">Groups: {{ groups | join(", ") }}</span>
            {% elif project.public == false %}
            <span class="badge badge-private">Private</span>
            {% endif %}
          </p>
          {% endif %}
        </div>
      </div>
    </a>
    {% endfor %}
  </div>
  {% endif %}
</section>
{% endblock %}

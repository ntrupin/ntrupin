{% extends "base.jinja" %}
{% block content %}
{% include "partials/mathjax.jinja" %}
<section class="post-page">
  {% if can_edit %}
  <a class="utility-button" href="{{ url_for('projects.update', id=project.id) }}">Edit</a>
  {% endif %}

  <h1 class="title post-title">{{ project.title }}</h1>
  <div class="post-meta-row">
    <p class="post-date">
      {% if project.started_on and project.ended_on %}
      {{ project.started_on.strftime("%B %Y") }} - {{ project.ended_on.strftime("%B %Y") }}
      {% elif project.started_on %}
      {{ project.started_on.strftime("%B %Y") }} - Present
      {% elif project.ended_on %}
      Through {{ project.ended_on.strftime("%B %Y") }}
      {% else %}
      {{ project.published_at.strftime("%B %d, %Y") }}
      {% endif %}
      {% if project.published_at != project.updated_at %}
      | Updated {{ project.updated_at.strftime("%B %d, %Y") }}
      {% endif %}
    </p>
  </div>

  {% if project.research == true or project.pinned == true or project.public == false or visibility_groups %}
  <p class="badge-line post-badges">
    {% if project.research == true %}<span class="badge">Research</span>{% endif %}
    {% if project.pinned == true %}<span class="badge">Pinned</span>{% endif %}
    {% if visibility_groups %}
    <span class="badge badge-private">Groups: {{ visibility_groups | join(", ") }}</span>
    {% elif project.public == false %}
    <span class="badge badge-private">Private</span>
    {% endif %}
  </p>
  {% endif %}

  <section class="glance-block" aria-labelledby="project-glance-heading">
    <h2 id="project-glance-heading" class="section-title">At a glance</h2>
    {% if project.deck %}<p class="post-summary">{{ project.deck }}</p>{% endif %}
    {% if project.summary %}<p class="post-summary">{{ project.summary }}</p>{% endif %}
    <dl class="fact-grid compact-facts">
      {% if project.status %}
      <div class="fact-row"><dt>Status</dt><dd>{{ project.status }}</dd></div>
      {% endif %}
      {% if project.stack %}
      <div class="fact-row"><dt>Stack</dt><dd>{{ project.stack }}</dd></div>
      {% endif %}
      {% if project.project_url or project.repo_url or project.paper_url %}
      <div class="fact-row">
        <dt>Links</dt>
        <dd class="link-row">
          {% if project.project_url %}<a href="{{ project.project_url }}" target="_blank" rel="noopener noreferrer">Live</a>{% endif %}
          {% if project.repo_url %}<a href="{{ project.repo_url }}" target="_blank" rel="noopener noreferrer">Code</a>{% endif %}
          {% if project.paper_url %}<a href="{{ project.paper_url }}" target="_blank" rel="noopener noreferrer">Paper</a>{% endif %}
        </dd>
      </div>
      {% endif %}
    </dl>
  </section>

  {% if project.content %}
  <article class="prose">
    {{ project.html | safe }}
  </article>
  {% endif %}
</section>
{% endblock %}

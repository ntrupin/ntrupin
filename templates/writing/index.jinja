{% extends "base.jinja" %}
{% block content %}
{% set featured_writing = writings | selectattr("pinned") | list %}
{% set archive_writing = writings | rejectattr("pinned") | list %}
<section>
  {% if g.user != None %}
  <a class="utility-button" href="{{ url_for('writing.create') }}">New essay</a>
  {% endif %}
  <h1 class="list-page-title">Writing</h1>

  {% if featured_writing %}
  <h2 class="section-title">Selected</h2>
  <div class="blog-list" role="list">
    {% for writing in featured_writing %}
    {% set groups = writing.visibility_groups if writing.visibility_groups is defined else [] %}
    <a
      href="{{ url_for('writing.show_canonical', name=writing.canonical_url) if writing.canonical_url else url_for('writing.show_id', id=writing.id) }}"
      class="blog-row"
      role="listitem"
    >
      <div class="blog-row-main">
        <p class="blog-date writing-date">{{ writing.published_at.strftime("%b %d, %Y") }}</p>
        <div class="blog-main-text">
          <p class="blog-title">{{ writing.title }}</p>
          {% if writing.summary %}<p class="blog-summary">{{ writing.summary }}</p>{% endif %}
          {% if writing.pinned == true or writing.public == false or groups %}
          <p class="badge-line">
            {% if writing.pinned == true %}<span class="badge">Pinned</span>{% endif %}
            {% if groups %}
            <span class="badge badge-private">Groups: {{ groups | join(", ") }}</span>
            {% elif writing.public == false %}
            <span class="badge badge-private">Private</span>
            {% endif %}
          </p>
          {% endif %}
        </div>
      </div>
    </a>
    {% endfor %}
  </div>
  {% endif %}

  {% if archive_writing %}
  <h2 class="section-title section-title-archive">{% if featured_writing %}Archive{% else %}All{% endif %}</h2>
  <div class="blog-list" role="list">
    {% for writing in archive_writing %}
    {% set groups = writing.visibility_groups if writing.visibility_groups is defined else [] %}
    <a
      href="{{ url_for('writing.show_canonical', name=writing.canonical_url) if writing.canonical_url else url_for('writing.show_id', id=writing.id) }}"
      class="blog-row"
      role="listitem"
    >
      <div class="blog-row-main">
        <p class="blog-date writing-date">{{ writing.published_at.strftime("%b %d, %Y") }}</p>
        <div class="blog-main-text">
          <p class="blog-title">{{ writing.title }}</p>
          {% if writing.summary %}<p class="blog-summary">{{ writing.summary }}</p>{% endif %}
          {% if writing.pinned == true or writing.public == false or groups %}
          <p class="badge-line">
            {% if writing.pinned == true %}<span class="badge">Pinned</span>{% endif %}
            {% if groups %}
            <span class="badge badge-private">Groups: {{ groups | join(", ") }}</span>
            {% elif writing.public == false %}
            <span class="badge badge-private">Private</span>
            {% endif %}
          </p>
          {% endif %}
        </div>
      </div>
    </a>
    {% endfor %}
  </div>
  {% endif %}
</section>
{% endblock %}

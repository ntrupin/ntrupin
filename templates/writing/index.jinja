{% extends "base.jinja" %}
{% block content %}
{% set selected_writings = writings | selectattr("pinned") | list %}
{% set archive_writings = writings | rejectattr("pinned") | list %}
<section class="page-section">
  {% if g.user != None %}
  <a class="button-link" href="{{ url_for('writing.create') }}">New essay</a>
  {% endif %}
  <h1 class="page-title">Writing</h1>
  <p class="section-intro">
    Essays, notes, and longer drafts in progress.
  </p>

  {% if selected_writings %}
  <section class="case-study-section" aria-labelledby="selected-writing-heading">
    <h2 id="selected-writing-heading" class="section-title">Selected essays</h2>
    <div class="case-study-list">
      {% for writing in selected_writings %}
      {% set groups = writing.visibility_groups if writing.visibility_groups is defined else [] %}
      <a href="{{ url_for('writing.show_canonical', name=writing.canonical_url) if writing.canonical_url else url_for('writing.show_id', id=writing.id) }}" class="case-study-item">
        <div class="case-study-header">
          <p class="case-study-index">{{ "%02d"|format(loop.index) }}</p>
          <h2 class="case-study-title">{{ writing.title }}</h2>
        </div>
        {% if writing.pinned == true or writing.public == false or groups %}
        <p class="project-badge-line case-study-badge-line">
          {% if writing.pinned == true %}
          <span class="badge-pinned">Pinned</span>
          {% endif %}
          {% if groups %}
          <span class="badge-private">Groups: {{ groups | join(", ") }}</span>
          {% elif writing.public == false %}
          <span class="badge-private">Private</span>
          {% endif %}
        </p>
        {% endif %}
        {% if writing.summary %}
        <p class="case-study-deck">{{ writing.summary }}</p>
        {% endif %}
        <p class="case-study-meta">
          <span>{{ writing.published_at.strftime("%b %d, %Y") }}</span>
        </p>
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {% if archive_writings %}
  <section class="collection-archive" {% if selected_writings %}aria-labelledby="writing-archive-heading"{% endif %}>
    {% if selected_writings %}
    <h2 id="writing-archive-heading" class="section-title">Archive</h2>
    {% endif %}
    <div class="collection-list">
      {% for writing in archive_writings %}
      {% set groups = writing.visibility_groups if writing.visibility_groups is defined else [] %}
      <a href="{{ url_for('writing.show_canonical', name=writing.canonical_url) if writing.canonical_url else url_for('writing.show_id', id=writing.id) }}" class="collection-item">
        <p class="collection-date">
          {{ writing.published_at.strftime("%b %d, %Y") }}
        </p>
        <div class="collection-content">
          <p class="collection-title">
            {{ writing.title }}
          </p>
          {% if writing.pinned == true or writing.public == false or groups %}
          <p class="project-badge-line">
            {% if writing.pinned == true %}
            <span class="badge-pinned">Pinned</span>
            {% endif %}
            {% if groups %}
            <span class="badge-private">Groups: {{ groups | join(", ") }}</span>
            {% elif writing.public == false %}
            <span class="badge-private">Private</span>
            {% endif %}
          </p>
          {% endif %}
          {% if writing.summary %}
          <p class="collection-summary-snippet">{{ writing.summary }}</p>
          {% endif %}
        </div>
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}
</section>
{% endblock %}

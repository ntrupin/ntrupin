{% extends "base.jinja" %}
{% block content %}
{% include "partials/mathjax.jinja" %}
<section class="post-page article-page">
  {% if can_edit %}
  <a class="utility-button" href="{{ url_for('writing.update', id=writing.id) }}">Edit</a>
  {% endif %}

  <h1 class="title post-title">{{ writing.title }}</h1>
  <div class="post-meta-row">
    <p class="post-date">
      {{ writing.published_at.strftime("%B %d, %Y") }}
      {% if writing.published_at != writing.updated_at %}
      | Updated {{ writing.updated_at.strftime("%B %d, %Y") }}
      {% endif %}
    </p>
  </div>

  {% if writing.pinned == true or writing.public == false or visibility_groups %}
  <p class="badge-line post-badges">
    {% if writing.pinned == true %}<span class="badge">Pinned</span>{% endif %}
    {% if visibility_groups %}
    <span class="badge badge-private">Groups: {{ visibility_groups | join(", ") }}</span>
    {% elif writing.public == false %}
    <span class="badge badge-private">Private</span>
    {% endif %}
  </p>
  {% endif %}

  <div class="article-shell" data-sidenote-root data-toc-root>
    <aside class="toc-rail" data-toc-column aria-label="Table of contents"></aside>
    <article class="prose" data-article-body>
      {{ writing.html | safe }}
    </article>
    <aside class="sidenote-rail" data-sidenote-column aria-label="Sidenotes"></aside>
  </div>
</section>
<script src="{{ url_for('static', filename='js/article_toc.js') }}"></script>
<script src="{{ url_for('static', filename='js/sidenotes.js') }}"></script>
{% endblock %}

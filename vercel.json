{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "version": 2,
    "builds": [
        {
            "src": "./noah.py",
            "use": "@vercel/python"
        },
        {
            "src": "/static/**",
            "use": "@vercel/static"
        }
    ],
    "headers": [
        {
            "source": "/static/:path*",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                },
                {
                    "key": "CDN-Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                },
                {
                    "key": "Vercel-CDN-Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/:path*",
            "destination": "/noah.py"
        }
    ]
}

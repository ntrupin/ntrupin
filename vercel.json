{
    "version": 2,
    "builds": [
        {
            "src": "./noah.py",
            "use": "@vercel/python"
        },
        {
            "src": "/static/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "headers": {
                "Cache-Control": "public, max-age=0, must-revalidate",
                "CDN-Cache-Control": "public, max-age=31536000, immutable",
                "Vercel-CDN-Cache-Control": "public, max-age=31536000, immutable"
            },
            "continue": true
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "noah.py"
        }
    ]
}
